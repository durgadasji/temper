{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "temper-color",
  "version": "1.0.0",
  "description": "Five-mode semantic color system. One shared token schema; each token carries a value per mode. Values are generated from the deriver (derive.js) at the middle notch, Iron family, default vision, the same source as theme.css. System is not a value set: it resolves at runtime to light or dark via prefers-color-scheme, per systemMapping.",
  "modes": [
    "light",
    "soft-light",
    "soft-dark",
    "dark"
  ],
  "systemMapping": {
    "light": "light",
    "dark": "dark"
  },
  "cssVariablePattern": "token path with slashes becomes --color-<segments joined by dash>, e.g. background/base -> --color-bg-base (bg is the documented abbreviation for background).",
  "tokens": {
    "background/base": {
      "$type": "color",
      "$description": "Page background behind everything.",
      "values": {
        "light": "#F0F4F9",
        "soft-light": "#DBDEE3",
        "soft-dark": "#24272A",
        "dark": "#14161A"
      }
    },
    "background/subtle": {
      "$type": "color",
      "$description": "Recessed background for wells and sidebars, one step below base.",
      "values": {
        "light": "#E7EAF0",
        "soft-light": "#D1D5DA",
        "soft-dark": "#1D2024",
        "dark": "#0E1013"
      }
    },
    "surface/default": {
      "$type": "color",
      "$description": "Raised surface for cards, panels, and menus.",
      "values": {
        "light": "#FFFFFF",
        "soft-light": "#FFFFFF",
        "soft-dark": "#323539",
        "dark": "#25282C"
      }
    },
    "surface/hover": {
      "$type": "color",
      "$description": "Surface under a hovered interactive element.",
      "values": {
        "light": "#F2F5FB",
        "soft-light": "#F2F5FB",
        "soft-dark": "#383B3F",
        "dark": "#2B2E32"
      }
    },
    "surface/active": {
      "$type": "color",
      "$description": "Surface under a pressed or selected element.",
      "values": {
        "light": "#E7EBF0",
        "soft-light": "#E7EBF0",
        "soft-dark": "#3E4145",
        "dark": "#323539"
      }
    },
    "border/default": {
      "$type": "color",
      "$description": "Standard hairline separator and control border.",
      "values": {
        "light": "#C9CDD1",
        "soft-light": "#B6BABF",
        "soft-dark": "#3D4044",
        "dark": "#313438"
      }
    },
    "border/strong": {
      "$type": "color",
      "$description": "Higher-contrast border for emphasis and dividers.",
      "values": {
        "light": "#A7AAAF",
        "soft-light": "#969A9F",
        "soft-dark": "#55585C",
        "dark": "#494C50"
      }
    },
    "text/primary": {
      "$type": "color",
      "$description": "Body and heading text. Meets WCAG AA on base and surface.",
      "values": {
        "light": "#17181A",
        "soft-light": "#060708",
        "soft-dark": "#F9FAFD",
        "dark": "#EFF1F4"
      }
    },
    "text/secondary": {
      "$type": "color",
      "$description": "Supporting text and labels. Meets AA on base.",
      "values": {
        "light": "#3F4143",
        "soft-light": "#37383B",
        "soft-dark": "#BFC1C4",
        "dark": "#B8BABD"
      }
    },
    "text/tertiary": {
      "$type": "color",
      "$description": "Muted metadata and placeholders. Large or non-essential text.",
      "values": {
        "light": "#56595C",
        "soft-light": "#4E5053",
        "soft-dark": "#9EA1A4",
        "dark": "#979A9D"
      }
    },
    "text/on-accent": {
      "$type": "color",
      "$description": "Foreground on a solid accent fill.",
      "values": {
        "light": "#FFFFFF",
        "soft-light": "#FFFFFF",
        "soft-dark": "#FFFFFF",
        "dark": "#FFFFFF"
      }
    },
    "accent/default": {
      "$type": "color",
      "$description": "Interactive accent for links, icons, and active state. Meets AA on base.",
      "values": {
        "light": "#1E4E8C",
        "soft-light": "#0F417E",
        "soft-dark": "#86BAFF",
        "dark": "#76A9EE"
      }
    },
    "accent/hover": {
      "$type": "color",
      "$description": "Accent under hover.",
      "values": {
        "light": "#0A3E7A",
        "soft-light": "#003068",
        "soft-dark": "#AFD1FF",
        "dark": "#90C0FF"
      }
    },
    "accent/subtle": {
      "$type": "color",
      "$description": "Tinted accent background for selected rows and quiet emphasis.",
      "values": {
        "light": "#C9E0FF",
        "soft-light": "#AFCCF3",
        "soft-dark": "#1E3555",
        "dark": "#112846"
      }
    },
    "accent/solid": {
      "$type": "color",
      "$description": "Fill for primary buttons. Pairs with text/on-accent at AA.",
      "values": {
        "light": "#3364A4",
        "soft-light": "#3364A4",
        "soft-dark": "#4274B5",
        "dark": "#4274B5"
      }
    },
    "success/default": {
      "$type": "color",
      "$description": "Positive status foreground.",
      "values": {
        "light": "#255D34",
        "soft-light": "#165028",
        "soft-dark": "#84BE90",
        "dark": "#74AE80"
      }
    },
    "success/subtle": {
      "$type": "color",
      "$description": "Positive status background.",
      "values": {
        "light": "#CAE7CF",
        "soft-light": "#B6D3BB",
        "soft-dark": "#213926",
        "dark": "#142B19"
      }
    },
    "warning/default": {
      "$type": "color",
      "$description": "Caution status foreground.",
      "values": {
        "light": "#704C00",
        "soft-light": "#604000",
        "soft-dark": "#D6AA66",
        "dark": "#C59A56"
      }
    },
    "warning/subtle": {
      "$type": "color",
      "$description": "Caution status background.",
      "values": {
        "light": "#F3DCBC",
        "soft-light": "#DFC8A8",
        "soft-dark": "#423014",
        "dark": "#342306"
      }
    },
    "danger/default": {
      "$type": "color",
      "$description": "Error and destructive status foreground. Meets AA on base.",
      "values": {
        "light": "#913327",
        "soft-light": "#82251A",
        "soft-dark": "#FD9483",
        "dark": "#EC8474"
      }
    },
    "danger/subtle": {
      "$type": "color",
      "$description": "Error status background.",
      "values": {
        "light": "#FFD6CF",
        "soft-light": "#F5BFB5",
        "soft-dark": "#522721",
        "dark": "#431A14"
      }
    },
    "focus/ring": {
      "$type": "color",
      "$description": "Keyboard focus ring.",
      "values": {
        "light": "#2D5D9C",
        "soft-light": "#1F508E",
        "soft-dark": "#73A6EB",
        "dark": "#6497DA"
      }
    },
    "selection/background": {
      "$type": "color",
      "$description": "Text selection highlight.",
      "values": {
        "light": "#ABCFFF",
        "soft-light": "#98BCED",
        "soft-dark": "#21416A",
        "dark": "#15345C"
      }
    },
    "code/background": {
      "$type": "color",
      "$description": "Background for inline and block code.",
      "values": {
        "light": "#E1E5EA",
        "soft-light": "#CCD0D5",
        "soft-dark": "#191C20",
        "dark": "#0A0C10"
      }
    },
    "code/text": {
      "$type": "color",
      "$description": "Code foreground. Meets AA on code/background.",
      "values": {
        "light": "#17181A",
        "soft-light": "#060708",
        "soft-dark": "#F9FAFD",
        "dark": "#EFF1F4"
      }
    },
    "table/stripe": {
      "$type": "color",
      "$description": "Zebra-stripe background for alternate table rows.",
      "values": {
        "light": "#F7FAFF",
        "soft-light": "#E1E5EA",
        "soft-dark": "#1F2225",
        "dark": "#0F1215"
      }
    },
    "overlay": {
      "$type": "color",
      "$description": "Scrim behind modals and drawers.",
      "values": {
        "light": "rgba(1, 2, 3, 0.45)",
        "soft-light": "rgba(1, 2, 3, 0.45)",
        "soft-dark": "rgba(1, 2, 3, 0.58)",
        "dark": "rgba(1, 2, 3, 0.58)"
      }
    }
  }
}
